<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Вход / Регистрация — КиноСоветник</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/css/account.css">
</head>
<body>
    <div class="cinema-bg"></div>
    <div class="overlay-glow"></div>

    <!-- КНОПКА ВОЗВРАТА НА ГЛАВНУЮ СТРАНИЦУ ( / ) -->
    <a href="/" class="back-home-btn" id="backHomeBtn">
        <i class="fas fa-arrow-left"></i>
        <span>На главную</span>
    </a>

    <div class="auth-container">
        <div class="auth-inner">
            <div class="logo-header">
                <div class="logo-icon"><i class="fas fa-film"></i></div>
                <h2>Movie Scout</h2>
                <p style="font-size: 0.75rem; margin-top: 4px;">вход в персонализированный мир кино</p>
            </div>

            <!-- переключатель вкладок -->
            <div class="tabs">
                <button class="tab-btn active" id="loginTabBtn">🔐 Вход</button>
                <button class="tab-btn" id="registerTabBtn">📝 Регистрация</button>
            </div>

            <!-- форма входа -->
            <div id="loginForm" class="form-panel">
                <div id="loginError" class="error-message hidden"></div>
                <div class="form-group">
                    <label class="input-label">Электронная почта</label>
                    <div class="input-icon-wrapper">
                        <i class="fas fa-envelope"></i>
                        <input type="email" id="loginEmail" placeholder="hello@kinoscout.ru" autocomplete="email">
                    </div>
                </div>
                <div class="form-group">
                    <label class="input-label">Пароль</label>
                    <div class="input-icon-wrapper">
                        <i class="fas fa-lock"></i>
                        <input type="password" id="loginPassword" placeholder="••••••••">
                    </div>
                </div>
                <button class="auth-btn" id="doLoginBtn"><i class="fas fa-arrow-right-to-bracket"></i> Войти в аккаунт</button>
                <div class="switch-message">
                    Нет аккаунта?
                    <button class="switch-link" id="switchToRegisterBtn">Создать аккаунт</button>
                </div>
                <div class="separator">
                    <span class="separator-line"></span>
                    <span>или через соцсети</span>
                    <span class="separator-line"></span>
                </div>
                <div class="social-buttons">
                    <button class="social-btn" id="googleMockBtn"><i class="fab fa-google"></i> Google</button>
                    <button class="social-btn" id="vkMockBtn"><i class="fab fa-vk"></i> VK</button>
                </div>
            </div>

            <!-- форма регистрации -->
            <div id="registerForm" class="form-panel hidden">
                <div id="registerError" class="error-message hidden"></div>
                <div class="form-group">
                    <label class="input-label">Имя (как в кино)</label>
                    <div class="input-icon-wrapper">
                        <i class="fas fa-user"></i>
                        <input type="text" id="regName" placeholder="Алексей" autocomplete="name">
                    </div>
                </div>
                <div class="form-group">
                    <label class="input-label">Электронная почта</label>
                    <div class="input-icon-wrapper">
                        <i class="fas fa-envelope"></i>
                        <input type="email" id="regEmail" placeholder="hello@kinoscout.ru">
                    </div>
                </div>
                <div class="form-group">
                    <label class="input-label">Пароль (минимум 6 символов)</label>
                    <div class="input-icon-wrapper">
                        <i class="fas fa-lock"></i>
                        <input type="password" id="regPassword" placeholder="придумайте пароль">
                    </div>
                </div>
                <div class="form-group">
                    <label class="input-label">Подтверждение пароля</label>
                    <div class="input-icon-wrapper">
                        <i class="fas fa-check-circle"></i>
                        <input type="password" id="regConfirmPassword" placeholder="повторите пароль">
                    </div>
                </div>
                <button class="auth-btn" id="doRegisterBtn"><i class="fas fa-user-plus"></i> Зарегистрироваться</button>
                <div class="switch-message">
                    Уже есть аккаунт?
                    <button class="switch-link" id="switchToLoginBtn">Войти</button>
                </div>
                <div class="separator">
                    <span class="separator-line"></span>
                    <span>или через соцсети</span>
                    <span class="separator-line"></span>
                </div>
                <div class="social-buttons">
                    <button class="social-btn" id="googleRegMockBtn"><i class="fab fa-google"></i> Google</button>
                    <button class="social-btn" id="vkRegMockBtn"><i class="fab fa-vk"></i> VK</button>
                </div>
            </div>

            <div class="footer-note">
                <i class="fas fa-shield-alt"></i> Ваши данные защищены. Продолжая, вы принимаете условия использования.
            </div>
        </div>
    </div>

    <script src="/js/account.js" type="module"></script>
</body>
</html>