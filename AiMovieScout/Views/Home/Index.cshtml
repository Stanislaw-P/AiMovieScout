@{
    ViewData["Title"] = "Movie Scout — рекомендации фильмов по сюжету";
    Layout = null;
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

    <!-- КНОПКИ В ШАПКЕ: избранное + авторизация -->
    <div class="top-bar">
        <button class="top-bar-btn" id="favoritesBtn">
            <i class="fas fa-heart"></i> Избранное
            <span id="favoritesCount" class="favorites-badge-count">0</span>
        </button>
        <button class="top-bar-btn" id="authBtn">
            <i class="fas fa-sign-in-alt"></i> Войти
        </button>
    </div>

    <!-- МОДАЛЬНОЕ ОКНО ДЛЯ ИЗБРАННЫХ ФИЛЬМОВ -->
    <div id="favoritesModal" class="favorites-modal">
        <div class="favorites-modal-content">
            <button class="close-modal" id="closeModalBtn">&times;</button>
            <h2><i class="fas fa-heart" style="color:#ff6680;"></i> Мои избранные фильмы</h2>
            <div id="favoritesListContainer">
                <!-- Список избранного будет отрисован здесь -->
            </div>
        </div>
    </div>

    <div class="marquee-wrapper">
        <div class="marquee-track">
            <!-- 5 уникальных обложек (замените пути на свои реальные файлы) -->
            <img src="/images/титаник.webp" alt="Титаник">
            <img src="/images/достучаться до небес.jpg" alt="Достучаться до небес">
            <img src="/images/мстители.jpg" alt="Мстители">
            <img src="/images/лала-ленд.jpg" alt="Ла-ла-ленд">
            <img src="/images/анора.jpg" alt="Анора">

            <!-- Дублируем для бесконечного цикла -->
            <img src="/images/титаник.webp" alt="Титаник">
            <img src="/images/достучаться до небес.jpg" alt="Достучаться до небес">
            <img src="/images/мстители.jpg" alt="Мстители">
            <img src="/images/лала-ленд.jpg" alt="Ла-ла-ленд">
            <img src="/images/анора.jpg" alt="Анора">
        </div>
    </div>
    <div class="overlay-dark"></div>

    <div class="content">
        <div class="hero-card text-center mb-4">
            <h1 class="mb-3">🎬 КиноСоветник</h1>
            <p class="lead mb-4">Расскажите, какие фильмы вам нравятся — ИИ подберёт для вас <strong>кино по сюжету</strong> и настроению</p>

            <form id="recommendForm">
                <div class="mb-4 text-start">
                    <label class="form-label fs-5">📝 Ваши любимые фильмы (через запятую)</label>
                    <textarea class="form-control" rows="3" id="moviesInput" placeholder="Пример: 1+1, Зеленая миля, Начало, Титаник, Достучаться до небес ..."></textarea>
                    <div class="form-text text-light-emphasis mt-2">Укажите 2–5 фильмов, которые вам особенно по душе</div>
                </div>
                <button type="submit" class="btn btn-primary-custom px-5 py-2" id="submitBtn">
                    🔍 Подобрать фильмы
                </button>
            </form>
        </div>

        <!-- Блок с рекомендациями (увеличенный) -->
        <div id="recommendationsBlock" class="container mt-4" style="max-width: 950px;">
            <div id="resultsArea" class="row g-4 justify-content-center">
                <!-- Сюда динамически добавим карточки рекомендаций -->
            </div>
        </div>
        <footer class="mt-5 text-center">
            <p>✨ Рекомендации на основе анализа сюжетов — AI подбирает похожие по духу фильмы</p>
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js//index.js"></script>
    <script>
        // Пример для демонстрации (инициализация)
        document.getElementById('moviesInput').value = "Титаник, Достучаться до небес";
        updateFavCounter();
    </script>
</body>
</html>